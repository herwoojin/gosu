# ── 데모 모드 ──────────────────────────────────────────────
# 아래 키들을 채우지 않으면 앱은 자동으로 "데모 모드"로 동작합니다.
# (Firebase/Supabase 없이 mock 데이터로 전 화면 탐색 가능)
# 실제 서비스 연결 시 이 파일을 .env.local 로 복사하고 값을 채우세요.

# Firebase (클라이언트 공개키 — NEXT_PUBLIC_ 접두사 허용)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE=

# 서버 전용 (클라이언트 절대 노출 금지)
NTS_BIZ_API_KEY=
TOSS_SECRET_KEY=
ANTHROPIC_API_KEY=
KAKAO_REST_API_KEY=
